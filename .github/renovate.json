{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>gabe565/renovate-config"
  ],
  "regexManagers": [
    {
      "fileMatch": ["Dockerfile", "^\\.github/workflows/", "README.md"],
      "matchStrings": [
        "\\s*RESTIC_IMAGE: +(?<depName>.+)\\n\\s*RESTIC_TAG: +(?<currentValue>.+)@(?<currentDigest>.+)",
        "ARG +RESTIC_IMAGE=(?<depName>.+)\\nARG +RESTIC_TAG=(?<currentValue>.+)@(?<currentDigest>.+)",
        "<!--renovate image=(?<depName>.+) -->\\n.*\\/Version-v(?<currentValue>.+?)-"
      ],
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/restic/restic"],
      "automerge": true
    }
  ]
}
